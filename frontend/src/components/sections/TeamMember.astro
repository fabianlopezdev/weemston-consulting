---
/**
 * TeamMember
 *
 * Editorial bio section for the Our Team page. Mirrors the title typography
 * used by AboutTwoColumn on the journey page (Lora serif, --font-size-3xl,
 * weight 400, primary color, left-aligned), so a "Sarah Przybocki" or
 * "Jennifer L. Scully, Ed.D." here reads as the same kind of section title
 * as "The Woman Behind Weemston Consulting" there.
 *
 * Layout: asymmetric two-column grid. Portrait in the narrower column;
 * eyebrow (number + role) + name + bio in the wider column. The `reverse`
 * prop swaps which side the portrait sits on for editorial rhythm.
 */
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  name: string;
  role: string;
  image: ImageMetadata;
  imageAlt: string;
  bioParagraphs: string[];
  reverse?: boolean;
}

const {
  name,
  role,
  image,
  imageAlt,
  bioParagraphs,
  reverse = false,
} = Astro.props;
---

<article
  class:list={['team-member', { 'team-member--reverse': reverse }]}
  data-team-member
>
  <div class="container">
    <div class="team-member__grid">
      <figure class="team-member__portrait" data-team-portrait>
        <Image
          src={image}
          alt={imageAlt}
          format="webp"
          quality={82}
          widths={[480, 720, 960, 1200]}
          sizes="(max-width: 768px) 100vw, (max-width: 1200px) 38vw, 480px"
          class="team-member__image"
        />
      </figure>
      <div class="team-member__content">
        <p class="team-member__eyebrow" data-team-eyebrow>{role}</p>
        <h2 class="team-member__name" data-team-name>{name}</h2>
        <div class="team-member__bio">
          {bioParagraphs.map((paragraph) => <p data-team-bio>{paragraph}</p>)}
        </div>
      </div>
    </div>
  </div>
</article>

<style>
  .team-member {
    color: var(--color-text);
    padding-block: clamp(4rem, 9vw, 8rem);
  }

  .team-member {
    --tm-grid-cols: 5fr 7fr;
    --tm-portrait-pos: 1;
    --tm-content-pos: 2;
  }

  .team-member--reverse {
    --tm-grid-cols: 7fr 5fr;
    --tm-portrait-pos: 2;
    --tm-content-pos: 1;
  }

  .team-member__grid {
    display: grid;
    grid-template-columns: var(--tm-grid-cols);
    gap: clamp(2rem, 6vw, 5.5rem);
    align-items: center;
  }

  .team-member__portrait {
    grid-column: var(--tm-portrait-pos);
    grid-row: 1;
    margin: 0;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    border-radius: var(--border-radius-md);
    background-color: color-mix(in srgb, var(--color-text) 4%, transparent);
    will-change: transform;
  }

  /* Mirrors the image hover treatment used by AboutTwoColumn/AboutTwoPhotos/
     AboutTextWrap on the journey page (scale 1.03, 0.5s ease). */
  .team-member__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  .team-member__portrait:hover .team-member__image {
    transform: scale(1.03);
  }

  .team-member__content {
    grid-column: var(--tm-content-pos);
    grid-row: 1;
    max-width: 60ch;
  }

  /* Editorial role label above the name */
  .team-member__eyebrow {
    margin: 0 0 clamp(1rem, 1.6vw, 1.5rem);
    font-family: var(--font-sans);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-medium);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  /* Mirrors .two-column__title from AboutTwoColumn so the name reads as the
     same title style as section titles on /the-journey. */
  .team-member__name {
    font-family: var(--font-heading);
    font-size: var(--font-size-3xl);
    font-weight: var(--font-weight-normal);
    color: var(--color-accent);
    line-height: 1.3;
    margin: 0 0 clamp(1.25rem, 2.4vw, 1.75rem);
  }

  .team-member__bio {
    display: flex;
    flex-direction: column;
    gap: clamp(0.875rem, 1.4vw, 1.25rem);
    font-family: var(--font-sans);
    font-size: var(--font-size-base);
    line-height: 1.7;
    color: color-mix(in srgb, var(--color-text) 88%, transparent);
  }

  .team-member__bio p {
    margin: 0;
    max-width: 58ch;
  }

  @media (max-width: 768px) {
    .team-member__grid,
    .team-member--reverse .team-member__grid {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }

    .team-member__portrait,
    .team-member--reverse .team-member__portrait,
    .team-member__content,
    .team-member--reverse .team-member__content {
      grid-column: 1;
      grid-row: auto;
    }

    .team-member__portrait,
    .team-member--reverse .team-member__portrait {
      order: 0;
    }

    .team-member__content,
    .team-member--reverse .team-member__content {
      order: 1;
      max-width: 100%;
    }

    .team-member__portrait {
      max-width: 26rem;
      margin-inline: auto;
      width: 100%;
    }

    .team-member__bio p {
      max-width: 100%;
    }
  }
</style>

<script>
  import { setupAnimationLifecycle, gsap, ScrollTrigger } from '@lib/animation';

  setupAnimationLifecycle(() => {
    const sections =
      document.querySelectorAll<HTMLElement>('[data-team-member]');
    if (!sections.length) return;

    sections.forEach((section) => {
      const portrait = section.querySelector<HTMLElement>(
        '[data-team-portrait]'
      );
      const eyebrow = section.querySelector<HTMLElement>('[data-team-eyebrow]');
      const name = section.querySelector<HTMLElement>('[data-team-name]');
      const bioParas = section.querySelectorAll<HTMLElement>('[data-team-bio]');

      const targets = [portrait, eyebrow, name, ...bioParas].filter(
        (el): el is HTMLElement => el !== null
      );
      gsap.set(targets, { y: 24, autoAlpha: 0 });

      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: section,
          start: 'top 75%',
          toggleActions: 'play none none none',
        },
        defaults: { ease: 'power3.out', duration: 0.9 },
      });

      if (portrait) tl.to(portrait, { y: 0, autoAlpha: 1 }, 0);
      if (eyebrow) tl.to(eyebrow, { y: 0, autoAlpha: 1, duration: 0.7 }, 0.15);
      if (name) tl.to(name, { y: 0, autoAlpha: 1, duration: 0.8 }, 0.22);
      if (bioParas.length)
        tl.to(
          bioParas,
          { y: 0, autoAlpha: 1, duration: 0.7, stagger: 0.08 },
          0.32
        );
    });

    ScrollTrigger.refresh();
  });
</script>
