---
/**
 * TeamMember
 *
 * Editorial bio section for /our-team. Receives a Sanity teamMember document
 * and a positional `index`; layout rhythm (portrait side + bg tone) is
 * derived from the index automatically — even members get plain bg with
 * portrait left, odd members get a soft cream tint with portrait right.
 *
 * Mirrors the title typography of AboutTwoColumn on /the-journey (Lora
 * serif, --font-size-3xl, weight 400, accent color, left-aligned) and reuses
 * the hover/portrait treatment used by the about sections.
 *
 * The bio is PortableText. Inserting a `pullQuote` block in the studio
 * renders as a centered italic Lora callout between the surrounding
 * paragraphs (see TeamMemberPullQuote.astro).
 */
import { PortableText } from 'astro-portabletext';
import type { PortableTextBlock } from '@portabletext/types';
import type { SanityImageSource } from '@sanity/image-url/lib/types/types';
import Image from '@components/media/Image.astro';
import TeamMemberPullQuote from './TeamMemberPullQuote.astro';

interface SanityImage {
  asset?: SanityImageSource;
  alt?: string;
  hotspot?: { x: number; y: number };
  crop?: { top: number; bottom: number; left: number; right: number };
}

interface Member {
  _id?: string;
  name: string;
  nameAccent?: string;
  role: string;
  image: SanityImage;
  bio: PortableTextBlock[];
}

interface Props {
  member: Member;
  index: number;
}

const { member, index } = Astro.props;
const { name, nameAccent, role, image, bio } = member;

// Layout rhythm derived from position: even = plain bg / portrait left,
// odd = cream tint / portrait right.
const reverse = index % 2 === 1;
const tone: 'plain' | 'cream' = reverse ? 'cream' : 'plain';

// Italicize the configured substring of the name (if any) without
// introducing JSX-whitespace artifacts.
const accentIndex =
  nameAccent && name.includes(nameAccent) ? name.indexOf(nameAccent) : -1;
const namePartBefore = accentIndex > -1 ? name.slice(0, accentIndex) : name;
const namePartAccent =
  accentIndex > -1
    ? name.slice(accentIndex, accentIndex + (nameAccent?.length ?? 0))
    : '';
const namePartAfter =
  accentIndex > -1 ? name.slice(accentIndex + (nameAccent?.length ?? 0)) : '';

// Custom serializer: route the `pullQuote` block type to our component.
const portableTextComponents = {
  type: {
    pullQuote: TeamMemberPullQuote,
  },
};
---

<article
  class:list={['team-member', { 'team-member--reverse': reverse }]}
  data-tone={tone}
  data-team-member
>
  <div class="container">
    <div class="team-member__grid">
      <figure class="team-member__portrait" data-team-portrait>
        <Image
          image={image as SanityImageSource}
          alt={image?.alt || `Portrait of ${name}`}
          sizes="(max-width: 768px) 100vw, (max-width: 1200px) 38vw, 480px"
        />
      </figure>
      <div class="team-member__content" data-team-content>
        <p class="team-member__eyebrow" data-team-eyebrow>{role}</p>
        <h2
          class="team-member__name"
          data-team-name
          set:html={namePartAccent
            ? `${namePartBefore}<em>${namePartAccent}</em>${namePartAfter}`
            : name}
        />
        <div class="team-member__bio" data-team-bio>
          <PortableText value={bio} components={portableTextComponents} />
        </div>
      </div>
    </div>
  </div>
</article>

<style>
  .team-member {
    color: var(--color-text);
    padding-block: clamp(4rem, 9vw, 8rem);
  }

  .team-member[data-tone='cream'] {
    background-color: color-mix(in srgb, var(--color-primary) 35%, white);
  }

  .team-member {
    --tm-grid-cols: 5fr 7fr;
    --tm-portrait-pos: 1;
    --tm-content-pos: 2;
  }

  .team-member--reverse {
    --tm-grid-cols: 7fr 5fr;
    --tm-portrait-pos: 2;
    --tm-content-pos: 1;
  }

  .team-member__grid {
    display: grid;
    grid-template-columns: var(--tm-grid-cols);
    gap: clamp(2rem, 6vw, 5.5rem);
    align-items: start;
  }

  .team-member__portrait {
    grid-column: var(--tm-portrait-pos);
    grid-row: 1;
    margin: 0;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    border-radius: var(--border-radius-md);
    background-color: color-mix(in srgb, var(--color-text) 4%, transparent);
    will-change: transform;
  }

  /* Mirrors the image hover treatment used by AboutTwoColumn/AboutTwoPhotos/
     AboutTextWrap on the journey page (scale 1.03, 0.5s ease). */
  .team-member__portrait :global(img),
  .team-member__portrait :global(.image-blur-wrapper) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  .team-member__portrait:hover :global(img) {
    transform: scale(1.03);
  }

  .team-member__content {
    grid-column: var(--tm-content-pos);
    grid-row: 1;
    max-width: 60ch;
  }

  .team-member__eyebrow {
    margin: 0 0 clamp(1rem, 1.6vw, 1.5rem);
    font-family: var(--font-sans);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-medium);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  /* Mirrors .two-column__title from AboutTwoColumn so the name reads as the
     same title style as section titles on /the-journey. */
  .team-member__name {
    font-family: var(--font-heading);
    font-size: var(--font-size-3xl);
    font-weight: var(--font-weight-normal);
    color: var(--color-accent);
    line-height: 1.3;
    margin: 0 0 clamp(1.25rem, 2.4vw, 1.75rem);
  }

  .team-member__name :global(em) {
    font-style: italic;
  }

  .team-member__bio {
    display: flex;
    flex-direction: column;
    gap: clamp(0.875rem, 1.4vw, 1.25rem);
    font-family: var(--font-sans);
    font-size: var(--font-size-base);
    line-height: 1.7;
    color: color-mix(in srgb, var(--color-text) 88%, transparent);
  }

  .team-member__bio :global(p) {
    margin: 0;
    max-width: 58ch;
  }

  /* Drop cap on the first paragraph of each bio. */
  .team-member__bio :global(p:first-of-type::first-letter) {
    float: left;
    font-family: var(--font-heading);
    font-size: 3.4em;
    line-height: 0.85;
    color: var(--color-accent);
    padding-top: 0.06em;
    padding-inline-end: 0.4rem;
  }

  /* Inline pull quote — sits between bio paragraphs, centered in the column. */
  .team-member__bio :global(.team-member__pull-quote) {
    margin: clamp(0.75rem, 1.2vw, 1.25rem) auto;
    max-width: 50ch;
    font-family: var(--font-heading);
    font-style: italic;
    font-size: clamp(1.25rem, 0.95rem + 1.4vw, 1.75rem);
    line-height: 1.4;
    color: var(--color-accent);
    text-align: center;
  }

  /* Inline marks inside bio */
  .team-member__bio :global(em) {
    font-style: italic;
  }

  .team-member__bio :global(strong) {
    font-weight: var(--font-weight-medium);
  }

  .team-member__bio :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
    transition: opacity var(--transition-fast);
  }

  .team-member__bio :global(a:hover) {
    opacity: 0.8;
  }

  @media (max-width: 768px) {
    .team-member__grid,
    .team-member--reverse .team-member__grid {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }

    .team-member__portrait,
    .team-member--reverse .team-member__portrait,
    .team-member__content,
    .team-member--reverse .team-member__content {
      grid-column: 1;
      grid-row: auto;
    }

    .team-member__portrait,
    .team-member--reverse .team-member__portrait {
      order: 0;
    }

    .team-member__content,
    .team-member--reverse .team-member__content {
      order: 1;
      max-width: 100%;
    }

    .team-member__portrait {
      max-width: 26rem;
      margin-inline: auto;
      width: 100%;
    }

    .team-member__bio :global(p) {
      max-width: 100%;
    }
  }
</style>

<script>
  import { setupAnimationLifecycle, gsap, ScrollTrigger } from '@lib/animation';

  setupAnimationLifecycle(() => {
    const sections =
      document.querySelectorAll<HTMLElement>('[data-team-member]');
    if (!sections.length) return;

    sections.forEach((section) => {
      const portrait = section.querySelector<HTMLElement>(
        '[data-team-portrait]'
      );
      const eyebrow = section.querySelector<HTMLElement>('[data-team-eyebrow]');
      const name = section.querySelector<HTMLElement>('[data-team-name]');
      const bio = section.querySelector<HTMLElement>('[data-team-bio]');

      const targets = [portrait, eyebrow, name, bio].filter(
        (el): el is HTMLElement => el !== null
      );
      gsap.set(targets, { y: 24, autoAlpha: 0 });

      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: section,
          start: 'top 75%',
          toggleActions: 'play none none none',
        },
        defaults: { ease: 'power3.out', duration: 0.9 },
      });

      if (portrait) tl.to(portrait, { y: 0, autoAlpha: 1 }, 0);
      if (eyebrow) tl.to(eyebrow, { y: 0, autoAlpha: 1, duration: 0.7 }, 0.15);
      if (name) tl.to(name, { y: 0, autoAlpha: 1, duration: 0.8 }, 0.22);
      if (bio) tl.to(bio, { y: 0, autoAlpha: 1, duration: 0.9 }, 0.32);
    });

    ScrollTrigger.refresh();
  });
</script>
