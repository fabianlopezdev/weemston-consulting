---
/**
 * Our Team Page
 *
 * Fully CMS-driven: hero comes from the `teamPage` singleton; member sections
 * come from the `teamMember` document type, ordered ascending by `order`.
 * Visual rhythm (portrait side + bg tone) alternates automatically by
 * position, so the editor only needs to reorder members.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import { sanityClient as client } from 'sanity:client';
import { teamPageQuery } from '@lib/sanity/queries';
import InternalPageHero from '@components/sections/InternalPageHero.astro';
import TeamMember from '@components/sections/TeamMember.astro';

const data = await client.fetch(teamPageQuery);
const page = data?.page ?? null;
const members = Array.isArray(data?.members) ? data.members : [];

if (!page) {
  return Astro.redirect('/404');
}

const pageTitle = page.title || 'Our Team | Weemston Consulting';
const pageDescription =
  page.metaDescription || 'Meet the people behind Weemston Consulting.';
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <InternalPageHero
    heading={page.heroHeading}
    headingHighlight={page.heroHeadingHighlight}
    tagline={page.heroTagline}
  />

  {
    members.length > 0 ? (
      <div class="team-members">
        {members.map((member: any, i: number) => (
          <TeamMember member={member} index={i} />
        ))}
      </div>
    ) : (
      <section class="team-members__empty">
        <div class="container">
          <p>Team members coming soon.</p>
        </div>
      </section>
    )
  }
</BaseLayout>

<style is:global>
  /* Subtle hairline between team members keeps the editorial rhythm. */
  .team-members > .team-member ~ .team-member {
    border-block-start: 1px solid
      color-mix(in srgb, var(--color-text) 8%, transparent);
  }
</style>

<style>
  .team-members__empty {
    padding-block: clamp(4rem, 9vw, 8rem);
    text-align: center;
    color: var(--color-text-muted);
  }
</style>
